{
    "compilerOptions": {
        "target": "esnext",
        "module": "nodenext",
        "types": ["node"],
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "./src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "**/*.test.ts"
    ]
}